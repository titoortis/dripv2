# --- Provider: BytePlus ModelArk Seedance 2.0 -----------------------------
# Get a key from https://console.byteplus.com/ark
ARK_API_KEY=
ARK_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3
ARK_DEFAULT_MODEL_ID=dreamina-seedance-2-0-260128

# --- Database -------------------------------------------------------------
DATABASE_URL="file:./dev.db"

# --- Object storage -------------------------------------------------------
# STORAGE_DRIVER=local       -> writes to STORAGE_LOCAL_DIR, served at /uploads
# STORAGE_DRIVER=s3          -> writes to S3-compatible bucket below
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./public/uploads
STORAGE_PUBLIC_BASE_URL=http://localhost:3000/uploads

S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=

# --- App ------------------------------------------------------------------
# Must be reachable from the public internet so Seedance can fetch
# the uploaded source image. In local dev that is just localhost.
APP_PUBLIC_BASE_URL=http://localhost:3000

# Background video for the landing hero. Public, mp4, autoplay-friendly
# (muted in code). The CloudFront URL hard-coded as the default in
# src/app/page.tsx is the project source-of-truth; override here for
# branch deploys / staging without a code change.
NEXT_PUBLIC_HERO_VIDEO_URL=

# Launch mode for the public deploy.
#   marketing -> only the landing renders; /create, /jobs/[id], /history
#                show "Coming soon" placeholders and never touch DB or
#                storage. Use this for a Vercel deploy without Postgres/S3.
#   full      -> default. Full generation pipeline is live.
NEXT_PUBLIC_LAUNCH_MODE=full

# Async polling
POLL_MIN_INTERVAL_MS=5000
POLL_MAX_INTERVAL_MS=20000
JOB_WALL_CLOCK_TIMEOUT_MS=600000

# Disable the in-process poller (e.g. on a serverless deploy like Vercel,
# where there is no long-lived process to host it).
DISABLE_POLLER=false

# Kill switch for the `reference_image` runner path. When false
# (default), the generation runner ignores any preset's
# `referenceMode = "reference_images"` and always submits the source
# image with role="first_frame" (the proven baseline). Flip to true
# only after Seedance task bodies with role="reference_image" have been
# live-validated end-to-end.
PROVIDER_REFERENCE_MODE_ENABLED=false

# Seedance prompt engineer (used by /api/prompt). One of these unlocks the
# landing's "Сделать промпт" button. If neither is set, the route returns
# HTTP 503 with a friendly message.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest
