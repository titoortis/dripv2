// dripv2 — Seedance 2.0 preset video MVP
//
// This file is the **canonical, production-targeted** Prisma schema. It is
// the schema Vercel's build step picks up (since `pnpm build` runs
// `prisma generate` with no `--schema` flag, which defaults to
// `prisma/schema.prisma`) and the schema you `prisma db push` against the
// prod Postgres database. `provider` is therefore `"postgresql"`.
//
// Local SQLite-based dev (`pnpm dev`, `pnpm db:push`, `pnpm db:seed`, etc.)
// uses an identical mirror at `prisma/schema.dev.prisma` whose only
// difference is `provider = "sqlite"`. The two files are kept byte-identical
// outside of the `datasource db { ... }` block by
// `scripts/check-prisma-schemas.cjs` (run on every `pnpm build`); see
// `scripts/check-prisma-schemas.cjs` for the parity rules.
//
// Anyone editing a model in this file MUST mirror the change into
// `prisma/schema.dev.prisma` in the same commit, or `pnpm build` will fail
// loudly. There is no auto-sync — the asymmetry is deliberate so that the
// production schema is reviewed independently.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Anonymous user, currently keyed by the browser session cookie. Real auth
// (Telegram or otherwise) lands later; when it does, we merge anonymous rows
// into a logged-in account by sessionId.
// ---------------------------------------------------------------------------
model User {
  id        String   @id @default(cuid())
  sessionId String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  wallet        EntitlementWallet?
  ledgerEntries JobLedgerEntry[]
  jobs          GenerationJob[]    @relation("JobByUser")
  jobsAsCreator GenerationJob[]    @relation("JobByCreator")
  presetsOwned  Preset[]           @relation("PresetByOwner")
  referralCodes ReferralCode[]
}

// ---------------------------------------------------------------------------
// Whole-video credit balance per user. One video = one credit.
// `trialGrantedAt` is a forward-only seam (no MVP writer): PR 2 used it to
// gate a first-visit trial grant; PR 3 rolled that back to a paid-only MVP.
// The column stays for future first-pack-discount logic etc.
// ---------------------------------------------------------------------------
model EntitlementWallet {
  id             String    @id @default(cuid())
  userId         String    @unique
  balance        Int       @default(0)
  trialGrantedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])
}

// ---------------------------------------------------------------------------
// Append-only audit trail of grant / debit / refund. We never UPDATE here.
// type ∈ {grant, debit, refund}. amount is always positive; sign is implied
// by `type`. `jobId` is null for "grant" entries that aren't tied to a job.
// ---------------------------------------------------------------------------
model JobLedgerEntry {
  id        String   @id @default(cuid())
  userId    String
  type      String
  amount    Int
  reason    String
  jobId     String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([jobId])
}

// ---------------------------------------------------------------------------
// Future-friendly seam for invite codes / influencer attribution.
// MVP creates none. Schema-only.
// ---------------------------------------------------------------------------
model ReferralCode {
  id          String   @id @default(cuid())
  code        String   @unique
  ownerUserId String
  createdAt   DateTime @default(now())

  owner          User            @relation(fields: [ownerUserId], references: [id])
  jobsAttributed GenerationJob[]
}

// ---------------------------------------------------------------------------
// Preset configuration. Editable without touching UI.
//
// `ownerUserId` / `visibility` / `royaltyBps` are future-friendly seams for
// creator presets and royalties (V1+). MVP seeds only platform-owned presets
// with `visibility="platform"` and `royaltyBps=0`. No UI exposes these.
// ---------------------------------------------------------------------------
model Preset {
  id             String   @id
  title          String
  subtitle       String?
  thumbnailUrl   String?
  promptTemplate String
  aspectRatio    String   @default("9:16")
  // `durationSec` and `resolution` remain the *baseline* render settings —
  // what `/api/jobs` POST always sends to the provider today. PR 5 adds the
  // capability fields below ("what could this preset render at?") as
  // forward-friendly seams for the PR 6 quality picker. Submit-time still
  // ignores them; nothing routes through the picker yet.
  durationSec    Int      @default(5)
  resolution     String   @default("720p")
  // CSV of supported render settings, sorted ascending. SQLite has no
  // first-class array type, so we use comma-separated strings; `/api/presets`
  // parses them back into typed arrays for clients.
  //   supportedResolutions ⊆ {"480p", "720p", "1080p"}
  //   supportedDurations   ⊆ {5, 10, 15}
  // Defaults intentionally narrow to the baseline so existing rows stay
  // truthful after a `prisma db push` without re-seeding.
  supportedResolutions String   @default("720p")
  supportedDurations   String   @default("5")
  generateAudio  Boolean  @default(false)
  motionNotes    String?
  modelId        String   @default("dreamina-seedance-2-0-260128")
  // Which provider-side content slot this preset's generation uses.
  //   "first_frame"      → image_url + role="first_frame" (Seedance
  //                        image-to-video baseline; current behavior).
  //   "reference_images" → same source image is sent with
  //                        role="reference_image". Same provider URL, just
  //                        a different content slot label. The kill switch
  //                        env `PROVIDER_REFERENCE_MODE_ENABLED` must also
  //                        be on for the runner to honor this — otherwise
  //                        the runner forces "first_frame".
  referenceMode  String   @default("first_frame")
  // Optional pre-transform pipeline. When non-null, the runner edits the
  // user's uploaded source image with the configured image model
  // (OpenAI Images Edit, model = `env.OPENAI_IMAGE_MODEL`) using this
  // prompt, persists the edited PNG to our storage, and submits that
  // URL to Seedance in place of the original. Used by presets where
  // the desired "first frame" is a stylized restage of the user's
  // photo (e.g. f1_pilot_v1 → Ferrari paddock portrait).
  //
  // Null means "submit the source image directly" (legacy path).
  transformPromptTemplate String?
  // Optional reference-sheet composition pipeline (PR: f1_pilot_v1, etc.).
  // When non-null, the runner first composes a multi-view character
  // reference sheet from the user's primary source image plus an outfit
  // reference image (`GenerationJob.outfitSourceImageId`), persists the
  // composed PNG as a `SourceImage` row, and feeds that URL into the
  // existing pre-transform / Seedance pipeline in place of the primary
  // source image. Submitted with this prompt to OpenAI Images Edit using
  // the `image[]` multi-image upload form (model =
  // `env.OPENAI_IMAGE_MODEL`, default `gpt-image-1`).
  //
  // Presets where this is non-null also require the client to send an
  // `outfitSourceImageId` on the `/api/jobs` POST — the API returns 400
  // `missing_outfit_image` otherwise. Null means "reference-sheet stage
  // is skipped" (legacy path, every preset today).
  referenceSheetPromptTemplate String?
  isActive       Boolean  @default(true)
  sortOrder      Int      @default(0)
  ownerUserId    String?
  visibility     String   @default("platform")
  royaltyBps     Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  owner User?           @relation("PresetByOwner", fields: [ownerUserId], references: [id])
  jobs  GenerationJob[]
}

// ---------------------------------------------------------------------------
// Source image uploaded by the user. We always control its URL.
// ---------------------------------------------------------------------------
model SourceImage {
  id         String   @id @default(cuid())
  storageKey String
  publicUrl  String
  mimeType   String
  width      Int?
  height     Int?
  bytes      Int
  createdAt  DateTime @default(now())

  // PR-B: `SourceImage` now backs two distinct slots on `GenerationJob` —
  // the primary `sourceImageId` (every job) and the optional
  // `outfitSourceImageId` (only presets that require an outfit reference).
  // Prisma requires explicit relation names when two relations connect the
  // same models. The underlying SQL FK constraints are independent; this
  // is purely a Prisma-client disambiguation.
  jobs           GenerationJob[] @relation("JobSourceImage")
  outfitJobs     GenerationJob[] @relation("JobOutfitImage")
}

// ---------------------------------------------------------------------------
// Generated video produced by Seedance and copied to our storage.
// ---------------------------------------------------------------------------
model ResultVideo {
  id           String   @id @default(cuid())
  storageKey   String
  publicUrl    String
  durationSec  Int?
  width        Int?
  height       Int?
  lastFrameUrl String?
  bytes        Int?
  createdAt    DateTime @default(now())

  job GenerationJob?
}

// ---------------------------------------------------------------------------
// Generation job — the central state machine.
// ---------------------------------------------------------------------------
model GenerationJob {
  id              String    @id @default(cuid())
  sessionId       String
  // `userId` is set on every job created after PR 2. Older jobs (from the
  // pre-PR-2 dev DB) may have null. Always derivable from `sessionId`.
  userId          String?
  // Future-friendly. Populated only when the preset has an owner != platform.
  creatorUserId   String?
  // Future-friendly. Populated when a referral code was active in the session.
  referralCodeId  String?
  presetId        String
  sourceImageId   String
  // PR-B: optional second `SourceImage` reference used as the outfit /
  // 2nd-selfie input for the stage-1 reference-sheet composition. Set
  // only on submits for presets that opt in via
  // `Preset.referenceSheetPromptTemplate`. Null on every legacy preset
  // (every preset today), in which case the runner skips stage 1 and
  // submits the primary source image through the existing path. Kept
  // nullable so prod jobs that were created before this column existed
  // (every prod row today) remain valid.
  outfitSourceImageId String?
  // PR 6 quality picker. The user's chosen render quality + the credits we
  // actually debited for this submission. Persisted on the row (not derived
  // from the preset baseline) because:
  //   - the runner submits with these exact values, not the preset's;
  //   - the wallet refund pays back exactly what we charged, not whatever
  //     the preset baseline would compute today (preset rows are mutable);
  //   - audit/ledger correctness must survive preset edits.
  // Defaults narrow to the PR4 baseline so existing rows (currently zero in
  // any deployed DB) stay truthful after `prisma db push`.
  resolution      String    @default("720p")
  durationSec     Int       @default(5)
  creditsCost     Int       @default(1)
  status          String    @default("queued")
  provider        String    @default("byteplus_seedance_2")
  providerModelId String
  providerTaskId  String?
  providerStatus  String?
  requestHash     String
  resultVideoId   String?   @unique
  errorCode       String?
  errorReason     String?
  // Observability-only classification of terminal failures —
  //   user | provider | operator | internal
  // Null while the job is non-terminal. Derived from errorCode at the
  // terminal-mark site via classifyFailure. Refund policy lives in
  // wallet.ts (REFUNDABLE_CODES + http_5* fallback) and is NOT replaced
  // by this column — failureKind is for instrumentation and future UX
  // copy, not money.
  failureKind     String?
  attempts        Int       @default(0)
  // Provider-side content-slot label actually used for the source image.
  // Populated by the runner at the queued → uploading transition, derived
  // from `(env.PROVIDER_REFERENCE_MODE_ENABLED, preset.referenceMode)`.
  // Persisted (not derived from the preset at read time) so the job's
  // history stays truthful even if the preset row's `referenceMode` or
  // the kill-switch env later changes. One of:
  //   "first_frame"      → legacy Seedance image-to-video baseline
  //   "reference_image"  → reference-mode content slot (PR 32+, gated by
  //                        the env kill switch at submit time)
  // Null while the job is still queued, and stays null on jobs that
  // failed before the runner reached the uploading transition (e.g.
  // `missing_api_key` short-circuit). UI badges should treat null as
  // "unknown" rather than rendering a misleading "first_frame" label.
  role            String?
  nextPollAt      DateTime?
  pollStartedAt   DateTime?
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  preset        Preset         @relation(fields: [presetId], references: [id])
  sourceImage   SourceImage    @relation("JobSourceImage", fields: [sourceImageId], references: [id])
  outfitSourceImage SourceImage? @relation("JobOutfitImage", fields: [outfitSourceImageId], references: [id])
  resultVideo   ResultVideo?   @relation(fields: [resultVideoId], references: [id])
  user          User?          @relation("JobByUser", fields: [userId], references: [id])
  creator       User?          @relation("JobByCreator", fields: [creatorUserId], references: [id])
  referralCode  ReferralCode?  @relation(fields: [referralCodeId], references: [id])

  @@unique([sessionId, requestHash])
  @@index([sessionId, createdAt])
  @@index([status, nextPollAt])
  @@index([userId, createdAt])
}
